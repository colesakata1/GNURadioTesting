# ──────────────────────────────────────────────────────────────────────────────
# CONNECTIONS
# ──────────────────────────────────────────────────────────────────────────────

connections:
# ── Transmitter path ──────────────────────────────────────────────────────────
- [analog_sig_source_x_0, '0', blocks_add_xx_0, '0']
- [analog_sig_source_x_1, '0', blocks_add_xx_0, '1']
- [analog_noise_source_x_0, '0', blocks_add_xx_0, '2']

# ── Display received signal ───────────────────────────────────────────────────
- [blocks_add_xx_0, '0', qtgui_time_sink_received, '0']
- [blocks_add_xx_0, '0', qtgui_freq_sink_received, '0']

# ── Cross-correlator for Source 1 ─────────────────────────────────────────────
